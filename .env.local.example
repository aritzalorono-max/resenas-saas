# ─── Supabase ─────────────────────────────────────────────────────────────────
# Crea tu proyecto en https://supabase.com y copia los valores desde:
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>        # solo servidor, no exponer

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000            # en producción: https://tu-dominio.com
