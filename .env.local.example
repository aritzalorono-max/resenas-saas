# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio — número compartido de la plataforma ReseñasYa (opción 1: shared)
# Sandbox: Account SID y Auth Token de la cuenta Twilio de ReseñasYa
# Número sandbox: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Places API (para seguimiento automático de puntuación en Maps)
GOOGLE_PLACES_API_KEY=

# Cron job protection — genera un secreto aleatorio largo (requerido)
CRON_SECRET=

# Backoffice admin — emails separados por comas (requerido para acceder a /admin)
ADMIN_EMAILS=admin@tudominio.com

# Vercel Analytics (para mostrar visitas en el backoffice)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Stripe (pagos y suscripciones)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Resend (formulario de contacto)
RESEND_API_KEY=re_...
